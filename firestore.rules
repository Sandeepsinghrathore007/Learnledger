rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function validActivityType(type) {
      return type in [
        'note_created',
        'topic_created',
        'topic_completed',
        'test_taken',
        'ai_question'
      ];
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.userId == userId;

      match /subjects/{subjectId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.userId == userId;

        match /pdfKnowledge/{pdfId} {
          allow read, delete: if isOwner(userId);
          allow create, update: if isOwner(userId) && request.resource.data.userId == userId;

          match /chunks/{chunkId} {
            allow read, delete: if isOwner(userId);
            allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
          }
        }

        match /topics/{topicId} {
          allow read, delete: if isOwner(userId);
          allow create, update: if isOwner(userId) && request.resource.data.userId == userId;

          match /notes/{noteId} {
            allow read, delete: if isOwner(userId);
            allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
          }
        }
      }

      match /tests/{testId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /aiChats/{chatId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
      }

      match /activity/{activityId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if
          isOwner(userId) &&
          request.resource.data.userId == userId &&
          validActivityType(request.resource.data.type);
      }

      match /examGroups/{examGroupId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && request.resource.data.userId == userId;
      }
    }

    // Required for collectionGroup queries (topics/notes across all subjects).
    // Client queries already filter by userId; this rule enforces owner-only reads.
    match /{path=**}/topics/{topicId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/notes/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
