# AI assistant mode:
# direct    = browser calls AI provider directly. No Firebase billing, but the AI key is exposed to the browser.
# functions = Firebase Cloud Functions backend. Recommended if you want to keep the key secret.
VITE_AI_ASSISTANT_MODE=direct
#
# Frontend direct AI setup:
# Use one browser key only if you accept that it is not secret in production.
# Prefer a provider/key that supports HTTP referrer restrictions.
# VITE_OPENROUTER_API_KEY=your_openrouter_key
# VITE_GEMINI_API_KEY=your_gemini_key
# Optional model overrides:
# VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-001
# VITE_GEMINI_MODEL=gemini-2.0-flash
#
# Firebase Functions backend setup:
# firebase functions:secrets:set OPENROUTER_API_KEY
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Firebase Web SDK config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
